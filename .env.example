# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# This file is for LOCAL DEVELOPMENT with `air` (hot-reload).
# Docker (production) uses its own environment block in docker-compose.yml.
# =============================================================================

SERVER_PORT=8080
CORS_ALLOW_ORIGIN=*
GIN_MODE=debug # Set to "release" in production for better performance and security.

# Database configuration.
# These values point to the Docker PostgreSQL container exposed on port 15432.
# Run `docker compose up -d` to start the database before running `air`.
DB_HOST=localhost
DB_PORT=15432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=permatatex_inventory
DB_SSLMODE=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME_MINUTES=30
DB_MAX_CONN_IDLE_TIME_MINUTES=10
DB_HEALTH_CHECK_PERIOD_SECONDS=30
DB_CONNECT_TIMEOUT_SECONDS=5

# Optional: override all DB_* values with a full DSN.
DB_URL=

# Secrets for JWT and Turnstile. Change these in production!
JWT_SECRET=change-me
TURNSTILE_SECRET=change-me

# Login endpoint rate limiting (per client IP, fixed window).
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# Server Timeout.
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s