# This is an example .env file for the backend. Copy this to .env and adjust the values as needed.
SERVER_PORT=8080
CORS_ALLOW_ORIGIN=*
GIN_MODE=debug # Set to "release" in production for better performance and security.

# Database configuration. Adjust these values according to your PostgreSQL setup.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=permatatex_inventory
DB_SSLMODE=disable

# Optional: override all DB_* values with a full DSN.
DB_URL=

# Secrets for JWT and Turnstile. Change these in production!
JWT_SECRET=change-me
TURNSTILE_SECRET=change-me